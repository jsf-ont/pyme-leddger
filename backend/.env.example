# BeanPCGE Environment Configuration

# Server
PORT=3001
NODE_ENV=production

# JWT Secret - CHANGE THIS IN PRODUCTION!
JWT_SECRET=beanpcge-super-secret-key-change-in-production

# Database (SQLite - no config needed for file-based)
# Database path is relative to server.js

# CORS (if needed)
# CORS_ORIGIN=http://localhost:5173

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001
