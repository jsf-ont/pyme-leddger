# BeanPCGE Environment Variables

# ============================================
# SUPABASE CONFIGURATION (Frontend)
# ============================================

# Your Supabase project URL (found in Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous key (found in Supabase Dashboard > Settings > API)
# Use the "anon" key, NOT the service_role key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Server port
PORT=3001

# Node environment
NODE_ENV=development

# JWT secret for backend authentication (when not using Supabase)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Backend API URL
VITE_API_URL=http://localhost:3001
